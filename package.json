{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "ingest": "tsx src/ingest.ts",
    "ingest:law": "tsx src/ingestLaw.ts",
    "ingest:commentary": "tsx src/ingestCommentary.ts",
    "ingest:irs": "tsx src/ingestIRS.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.mjs",
    "start": "node dist/server.mjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "groq-sdk": "^1.3.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdf-parse": "^2.4.5",
    "pdf-parse-fork": "^1.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pdf-parse": "^1.1.5",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.12",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.23.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}

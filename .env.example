# GEMINI_API_KEY: Required for Gemini embedding API calls.
# Used only for vector embeddings (gemini-embedding-2-preview).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GROQ_API_KEY: Required for Groq LLM generation calls.
# Get your key at https://console.groq.com
GROQ_API_KEY="MY_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# QDRANT_URL: Your Qdrant Cloud cluster URL.
# Get your free cluster at https://cloud.qdrant.io
QDRANT_URL="https://your-cluster-id.cloud.qdrant.io"

# QDRANT_API_KEY: Your Qdrant Cloud API key.
# Create one in the Qdrant Cloud dashboard under API Keys.
QDRANT_API_KEY="YOUR_QDRANT_API_KEY"
